# Copy to .env and adjust. See env.ts for the Zod schema.
#
# Required
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=http://192.168.1.5:3030/api/v1

# Optional (do not set EXPO_PUBLIC_ASSOCIATED_DOMAIN to an empty string)
# EXPO_PUBLIC_ASSOCIATED_DOMAIN=https://example.com
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — enable strict env validation (e.g. CI)
# STRICT_ENV_VALIDATION=1
